#!/usr/bin/env nu

def "main" [] {
  glob ($env.HOME)/{personal,work,homelab,github,gitlab,codeberg}/**/.git --depth 6
    | path dirname
    | prepend ($env.HOME)
    | sk --format {
      each { $in
        | path split
        | last 2
        | path join
      }
    } --preview-window up:50% --preview {
      $in
      | if ($in | session exists) { $in | session preview } else { ls $in }
    }
    | if ($in == null) { return } else { $in }
    | str trim
    | session switch
}

def "main path" [dir: path] {
  $dir
  | session switch
}

def "main clone" [ssh_url: string] {
  $ssh_url
  # | if ($in !~ ".*git.*@.*:.*.git") {
  #   print "Please provide a valid SSH url"
  #   return
  # } else { $in }
  | repo_path
  | if not ($in | path exists) {
    git clone $ssh_url $in;
    $in
  } else { $in }
  | main path $in
}

def repo_path []: [
  string -> string
] {
  let origin = $in

  let prefix = $env.HOME
  mut gitFolder = $origin
  | str replace "ssh://" ""
  | split row ":"
  | first
  | split row "@"
  | last
  | split row "."
  | drop 1
  | str join "-"

  if $gitFolder =~ "git-robowens" {
    $gitFolder = "homelab"
  }

  let repoFolder = $origin
  | split row ":"
  | last
  | str replace ".git" ""

  return ($prefix | path join $gitFolder | path join $repoFolder)
}

#!/usr/bin/env nu

def "main" [] {
  glob ($env.HOME)/{personal,work,homelab}/**/.git --depth 6
    | path dirname
    | prepend ($env.HOME)
    | sk --format {
      each { $in
        | path split
        | last 2
        | path join
      }
    } --preview-window up:50% --preview {
      $in
      | if ($in | session exists) { $in | session preview } else { ls $in }
    }
    | if ($in == null) { return } else { $in }
    | str trim
    | session switch
}

def "main path" [dir: path] {
  $dir
  | session switch
}

def "main clone" [ssh_url: string, depth?: int = 1] {
  $ssh_url
  | if ($in !~ ".*git.*@.*:.*.git") {
    print "Please provide a valid SSH url"
    return
  } else { $in }
  | if ($in | str contains "gitlab.clarkinc.biz") {
    $env.HOME
    | path join "work"
    | path join (
      $ssh_url
      | split row ":"
      | get 1
      | str replace ".git" ""
    );
  } else {
    $env.HOME
    | path join "personal"
    | path join (
      $ssh_url
      | split row ":"
      | get 1
      | str replace ".git" ""
    );
  }
  | if not ($in | path exists) {
    git clone --depth $depth $ssh_url $in;
    $in
  } else { $in }
  | main path $in
}


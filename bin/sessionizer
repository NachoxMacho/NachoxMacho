def friendly []: [
  path -> string
] {
  $in
  | each {
    path split
    | last 2
    | str join '-'
    | str replace -a '.' '_'
  }
}

def "session exists" []: [
path -> bool
] {
  $in
  | friendly
  | tmux has-session -t $in
  | complete
  | $in.exit_code == 0
}

def "session preview" []: [
  path -> string
] {
  $in
  | friendly
  | tmux capture-pane -pe -t $"($in):primary.0"
  | complete
  | get stdout
}

def "session create" [dir?: path]: [
  path -> nothing
] {
  $in
  | each {
    let path = $in
    let name = $in | friendly
    if $name =~ "home-.*" { # Generate some temporary panes
      tmux new-session -ds $name -n "secondary" -c $path
      tmux new-window -t $"($name)" -n "primary" -c $path
    } else {
      tmux new-session -ds $name -n "secondary" -c $path
      tmux new-window -t $"($name)" -n "primary" -c $path
      tmux send-keys -t $"($name):primary" "nvim" C-m
    }
  }
}

def "session switch" []: [
  path -> nothing
] {
  $in
  | if not ($in | session exists) { $in | session create; $in } else { $in }
  | friendly
  | if "TMUX" in $env { tmux switch-client -t $in } else { print ""; tmux new-session -A -t $in }
}
